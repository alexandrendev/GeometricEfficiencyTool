meta {
  name: Create New Simulation
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/simulation/new
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  Authorization: {{token}}
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "emissions": 10000,
    "sourceHeight": 0
  }
}
