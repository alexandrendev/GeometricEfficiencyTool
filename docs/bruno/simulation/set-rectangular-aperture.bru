meta {
  name: Set Rectangular Aperture
  type: http
  seq: 6
}

patch {
  url: {{baseUrl}}/simulation/rectangular
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "simulationId": "{{simulationId}}",
    "width": 10,
    "depth": 10,
    "height": 5
  }
}
